*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:#0f0f0f;
    color:#fff;
}

a{
    text-decoration:none;
    color:white;
}

img{
    width:100%;
    display:block;
}

header{
    width:100%;
    height:80px;
    background:#151515;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:0 60px;
    position:sticky;
    top:0;
    z-index:1000;
}

.logo{
    display:flex;
    align-items:center;
    gap:10px;
    font-size:28px;
    font-weight:700;
    color:#ff3d3d;
}

.logo i{
    font-size:32px;
}

nav{
    display:flex;
    gap:30px;
}

nav a{
    color:white;
    font-size:17px;
    transition:.3s;
}

nav a:hover{
    color:#ff3d3d;
}

.search{
    display:flex;
    align-items:center;
}

.search input{
    width:260px;
    padding:11px;
    border:none;
    outline:none;
    border-radius:25px 0 0 25px;
    background:#222;
    color:white;
}

.search button{
    padding:11px 18px;
    border:none;
    cursor:pointer;
    border-radius:0 25px 25px 0;
    background:#ff3d3d;
    color:white;
}

.profile{
    display:flex;
    align-items:center;
    gap:18px;
}

.profile button{
    width:42px;
    height:42px;
    border:none;
    border-radius:50%;
    background:#222;
    color:white;
    cursor:pointer;
    font-size:18px;
    transition:.3s;
}

.profile button:hover{
    background:#ff3d3d;
}

.profile img{
    width:42px;
    height:42px;
    border-radius:50%;
    cursor:pointer;
}

.hero{
    height:90vh;
    background:url("https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&w=1600&q=80");
    background-size:cover;
    background-position:center;
    position:relative;
}

.overlay{
    width:100%;
    height:100%;
    background:rgba(0,0,0,.6);
    display:flex;
    flex-direction:column;
    justify-content:center;
    padding-left:80px;
}

.overlay h1{
    width:700px;
    font-size:60px;
    line-height:75px;
}

.overlay p{
    width:600px;
    margin-top:20px;
    font-size:20px;
    color:#d4d4d4;
}

.hero-buttons{
    display:flex;
    gap:20px;
    margin-top:35px;
}

.hero-buttons button{
    padding:15px 30px;
    border:none;
    border-radius:30px;
    cursor:pointer;
    font-size:17px;
    transition:.3s;
}

.watch{
    background:#ff3d3d;
    color:white;
}

.watch:hover{
    transform:scale(1.05);
}

.list{
    background:white;
    color:black;
}

.list:hover{
    transform:scale(1.05);
}
.category{
    padding:60px 70px;
}

.category h2{
    font-size:32px;
    margin-bottom:30px;
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.card{
    background:#1b1b1b;
    border-radius:15px;
    overflow:hidden;
    cursor:pointer;
    transition:.4s;
    position:relative;
}

.card:hover{
    transform:translateY(-10px) scale(1.03);
    box-shadow:0 15px 35px rgba(255,61,61,.4);
}

.card img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.info{
    padding:18px;
}

.info h3{
    font-size:22px;
    margin-bottom:8px;
}

.info p{
    color:#bdbdbd;
    font-size:15px;
}

.card::before{
    content:"▶";
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    width:70px;
    height:70px;
    border-radius:50%;
    background:rgba(255,61,61,.9);
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:28px;
    opacity:0;
    transition:.4s;
}

.card:hover::before{
    opacity:1;
}

footer{
    background:#151515;
    text-align:center;
    padding:50px 20px;
    margin-top:50px;
}

footer h2{
    color:#ff3d3d;
    margin-bottom:15px;
    font-size:34px;
}

footer p{
    color:#bdbdbd;
    margin:10px 0;
}

.social{
    display:flex;
    justify-content:center;
    gap:25px;
    margin:25px 0;
}

.social i{
    font-size:28px;
    cursor:pointer;
    transition:.3s;
}

.social i:hover{
    color:#ff3d3d;
    transform:scale(1.2);
}

html{
    scroll-behavior:smooth;
}

::-webkit-scrollbar{
    width:10px;
}

::-webkit-scrollbar-track{
    background:#111;
}

::-webkit-scrollbar-thumb{
    background:#ff3d3d;
    border-radius:10px;
}

::-webkit-scrollbar-thumb:hover{
    background:#ff6666;
}

button{
    transition:.3s;
}

button:hover{
    opacity:.9;
}

@media(max-width:1100px){

header{
    flex-wrap:wrap;
    height:auto;
    padding:20px;
    gap:20px;
}

nav{
    flex-wrap:wrap;
    justify-content:center;
}

.search input{
    width:180px;
}

.overlay{
    padding:40px;
}

.overlay h1{
    width:100%;
    font-size:42px;
    line-height:55px;
}

.overlay p{
    width:100%;
}

.category{
    padding:40px;
}

}

@media(max-width:768px){

header{
    flex-direction:column;
}

.logo{
    font-size:24px;
}

nav{
    gap:15px;
}

nav a{
    font-size:15px;
}

.search{
    width:100%;
}

.search input{
    width:100%;
}

.hero{
    height:70vh;
}

.overlay{
    justify-content:center;
    text-align:center;
    align-items:center;
    padding:20px;
}

.overlay h1{
    font-size:34px;
    line-height:45px;
}

.overlay p{
    font-size:16px;
}

.hero-buttons{
    flex-direction:column;
    width:100%;
}

.hero-buttons button{
    width:220px;
}

.category{
    padding:25px;
}

.category h2{
    font-size:28px;
}

.cards{
    grid-template-columns:1fr;
}

footer h2{
    font-size:28px;
}

.social i{
    font-size:24px;
}

}

@media(max-width:480px){

.overlay h1{
    font-size:28px;
    line-height:38px;
}

.overlay p{
    font-size:14px;
}

.search input{
    font-size:14px;
}

.hero-buttons button{
    width:180px;
}

.category h2{
    font-size:24px;
}

.info h3{
    font-size:18px;
}

.info p{
    font-size:14px;
}

}
const themeButton = document.getElementById("theme");

themeButton.addEventListener("click", () => {

    document.body.classList.toggle("light");

    if(document.body.classList.contains("light")){
        themeButton.innerHTML = '<i class="fa-solid fa-sun"></i>';
        localStorage.setItem("theme","light");
    }
    else{
        themeButton.innerHTML = '<i class="fa-solid fa-moon"></i>';
        localStorage.setItem("theme","dark");
    }

});

const savedTheme = localStorage.getItem("theme");

if(savedTheme === "light"){

    document.body.classList.add("light");

    themeButton.innerHTML = '<i class="fa-solid fa-sun"></i>';

}

const searchInput = document.querySelector(".search input");

const cards = document.querySelectorAll(".card");

searchInput.addEventListener("keyup", () => {

    const value = searchInput.value.toLowerCase();

    cards.forEach(card => {

        const title = card.querySelector("h3").textContent.toLowerCase();

        if(title.includes(value)){
            card.style.display = "block";
        }
        else{
            card.style.display = "none";
        }

    });

});

cards.forEach(card => {

    card.addEventListener("click", () => {

        const title = card.querySelector("h3").textContent;

        alert("Now Playing: " + title);

    });

});

const watchButton = document.querySelector(".watch");

watchButton.addEventListener("click", () => {

    window.scrollTo({
        top:700,
        behavior:"smooth"
    });

});

const listButton = document.querySelector(".list");

listButton.addEventListener("click", () => {

    alert("Added to My List");

});

window.addEventListener("scroll", () => {

    const header = document.querySelector("header");

    if(window.scrollY > 100){

        header.style.background = "#000";

    }
    else{

        header.style.background = "#151515";

    }

});

const logo = document.querySelector(".logo");

logo.addEventListener("click", () => {

    window.scrollTo({
        top:0,
        behavior:"smooth"
    });

});
